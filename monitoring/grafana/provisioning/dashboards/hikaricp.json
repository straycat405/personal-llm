{
  "title": "BTLLM - HikariCP & JVM",
  "uid": "btllm-hikaricp",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HikariCP Active Connections",
      "description": "현재 쿼리 실행 중인 커넥션 수. maxPoolSize(10) 근접 시 병목 신호",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "red", "value": 9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"btllm\"}",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HikariCP Pending Connections",
      "description": "커넥션 대기 중인 스레드 수. 0 초과 시 풀 고갈 — 병목 핵심 지표",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{application=\"btllm\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HikariCP Connection Acquire Time (p99)",
      "description": "커넥션 획득까지 걸린 시간 p99. 높을수록 풀 경합 심함",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(hikaricp_connections_acquire_seconds_bucket{application=\"btllm\"}[1m]))",
          "legendFormat": "p99 acquire time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HikariCP Pool Size (Total / Idle)",
      "description": "전체 풀 크기 vs 유휴 커넥션. idle 0 = 모든 커넥션 사용 중",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections{application=\"btllm\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"btllm\"}",
          "legendFormat": "idle",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM Threads",
      "description": "JVM 스레드 수. Tomcat maxThreads=200 초과 여부 확인",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"btllm\"}",
          "legendFormat": "live threads",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Rate (req/s)",
      "description": "초당 처리 요청 수 — k6 부하와 대비",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"btllm\"}[1m])",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    }
  ]
}
